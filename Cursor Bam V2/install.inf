[Version]
Signature="$Windows NT$"
Class=Cursor
ClassGuid={4D36E96D-E325-11CE-BFC1-08002BE10318}

[DefaultInstall]
CopyFiles=CursorFiles
AddReg=CursorReg

[DestinationDirs]
CursorFiles=10,"%CURSOR_SUBFOLDER%"

[Strings]
CURSOR_SUBFOLDER=Cursors

[CursorFiles]
BamAeroWhitCatEars_arrow.cur
BamAero_ew.cur
BamAero_helpsel.cur
BamAero_move.cur
BamAero_nesw.cur
BamAero_ns.cur
BamLink.cur

[CursorReg]
HKCU,"Control Panel\Cursors","Arrow",,"%10%\Cursors\BamAeroWhitCatEars_arrow.cur"
HKCU,"Control Panel\Cursors","Help",,"%10%\Cursors\BamAero_helpsel.cur"
HKCU,"Control Panel\Cursors","SizeAll",,"%10%\Cursors\BamAero_move.cur"
HKCU,"Control Panel\Cursors","SizeNESW",,"%10%\Cursors\BamAero_nesw.cur"
HKCU,"Control Panel\Cursors","SizeNS",,"%10%\Cursors\BamAero_ns.cur"
HKCU,"Control Panel\Cursors","SizeWE",,"%10%\Cursors\BamAero_ew.cur"
HKCU,"Control Panel\Cursors","Hand",,"%10%\Cursors\BamLink.cur"


